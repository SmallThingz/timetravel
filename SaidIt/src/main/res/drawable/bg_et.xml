<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/background_panel" />
            <stroke
                android:width="1dp"
                android:color="@color/accent" />
            <corners android:radius="@dimen/small_round" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/background_input" />
            <stroke
                android:width="1dp"
                android:color="@color/border_subtle" />
            <corners android:radius="@dimen/small_round" />
        </shape>
    </item>
</selector>
