<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="@dimen/large_round" />
            <solid android:color="@color/button_dark_pressed" />
        </shape>
    </item>
    <item android:bottom="1dp">
        <shape>
            <padding
                android:bottom="@dimen/button_padding"
                android:left="20dp"
                android:right="20dp"
                android:top="@dimen/button_padding" />
            <corners android:radius="@dimen/large_round" />
            <stroke
                android:width="1dp"
                android:color="@color/border_strong" />
            <solid android:color="@color/button_dark_pressed" />
        </shape>
    </item>
</layer-list>
