<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners
                android:bottomLeftRadius="@dimen/large_round"
                android:bottomRightRadius="@dimen/large_round"
                android:topLeftRadius="0dp"
                android:topRightRadius="0dp" />
            <solid android:color="@color/shadow_base" />
        </shape>
    </item>
    <item android:bottom="@dimen/shadow_offset">
        <shape>
            <padding
                android:bottom="@dimen/small_round"
                android:left="@dimen/small_round"
                android:right="@dimen/small_round"
                android:top="0dp" />
            <corners
                android:bottomLeftRadius="@dimen/large_round"
                android:bottomRightRadius="@dimen/large_round"
                android:topLeftRadius="0dp"
                android:topRightRadius="0dp" />
            <stroke
                android:width="1dp"
                android:color="@color/border_subtle" />
            <solid android:color="@color/background_panel" />
        </shape>
    </item>
</layer-list>
