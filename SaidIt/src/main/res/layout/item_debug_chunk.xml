<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/chunk_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/recording_item_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chunk_name"
            style="?attr/textAppearanceLabelLarge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView
            android:id="@+id/chunk_active"
            style="?attr/textAppearanceLabelSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_circle_tonal"
            android:gravity="center"
            android:minWidth="34dp"
            android:minHeight="34dp"
            android:paddingHorizontal="12dp"
            android:text="@string/chunks_active"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/chunk_export_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_circle_outlined"
            android:contentDescription="@string/chunks_action_export"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:scaleType="center"
            android:src="@drawable/ic_chunk_export"
            app:tint="?attr/colorPrimary" />
    </LinearLayout>

    <TextView
        android:id="@+id/chunk_timing"
        style="?attr/textAppearanceBodyMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="monospace"
        android:textColor="?attr/colorOnSurface" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chunk_format"
            style="?attr/textAppearanceBodySmall"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/chunk_size"
            style="?attr/textAppearanceBodySmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <TextView
        android:id="@+id/chunk_path"
        style="?attr/textAppearanceBodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="middle"
        android:fontFamily="monospace"
        android:maxLines="2"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <TextView
        android:id="@+id/chunk_operations"
        style="?attr/textAppearanceBodySmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_circle_outlined"
        android:gravity="center"
        android:minHeight="34dp"
        android:paddingHorizontal="14dp"
        android:textColor="?attr/colorPrimary"
        android:visibility="gone" />

</LinearLayout>
