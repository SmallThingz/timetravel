<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_debug_panel"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chunk_name"
            style="?attr/textAppearanceLabelLarge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView
            android:id="@+id/chunk_active"
            style="?attr/textAppearanceLabelSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_circle_tonal"
            android:gravity="center"
            android:minWidth="32dp"
            android:minHeight="32dp"
            android:paddingHorizontal="10dp"
            android:text="@string/chunks_active"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/chunk_timing"
        style="?attr/textAppearanceBodyMedium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="monospace"
        android:textColor="?attr/colorOnSurface" />

    <TextView
        android:id="@+id/chunk_format"
        style="?attr/textAppearanceBodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <TextView
        android:id="@+id/chunk_operations"
        style="?attr/textAppearanceBodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="?attr/colorPrimary"
        android:visibility="gone" />
</LinearLayout>
