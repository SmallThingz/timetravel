<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/DialogPanel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        style="@style/SectionTitleSmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:tag="titleBar"
        android:text="@string/recording_done_title" />

    <TextView
        style="@style/LabelText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:tag="bold"
        android:text="@string/recording_done_filename" />

    <TextView
        android:id="@+id/recording_done_filename"
        style="@style/BodyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        style="@style/LabelText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:tag="bold"
        android:text="@string/recording_done_directory" />

    <TextView
        android:id="@+id/recording_done_dirname"
        style="@style/BodyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        style="@style/LabelText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:tag="bold"
        android:text="@string/recording_done_runtime" />

    <TextView
        android:id="@+id/recording_done_runtime"
        style="@style/BodyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        style="@style/LabelText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:tag="bold"
        android:text="@string/recording_done_size" />

    <TextView
        android:id="@+id/recording_done_size"
        style="@style/BodyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/recording_done_open"
            style="@style/TimeTravel.MaterialButton.Secondary.Small"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/open" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/recording_done_send"
            style="@style/TimeTravel.MaterialButton.Secondary.Small"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="@string/send" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/recording_done_close"
            style="@style/TimeTravel.MaterialButton.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="@string/close" />
    </LinearLayout>
</LinearLayout>
