<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_fragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="app.smallthingz.timetravel.TimeTravelFragment">

    <include layout="@layout/include_app_top_bar" />

    <!-- Main content when NOT recording -->
    <FrameLayout
        android:id="@+id/content_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Top info section: timer, subtitle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="28dp">

            <TextView
                android:id="@+id/history_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceDisplayLarge"
                android:textColor="?attr/colorOnSurface"
                android:typeface="monospace"
                tools:text="10:24:37" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/format_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    tools:text="12.0 MiB" />
            </FrameLayout>
        </LinearLayout>

        <!-- Big circle button -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:clipChildren="false"
            android:clipToPadding="false">

            <View
                android:id="@+id/listen_ring"
                android:layout_width="282dp"
                android:layout_height="282dp"
                android:layout_gravity="center"
                android:background="@drawable/listen_surface_outer_ring" />

            <FrameLayout
                android:id="@+id/bottom_bar"
                android:layout_width="232dp"
                android:layout_height="232dp"
                android:layout_gravity="center"
                android:clickable="true"
                android:clipChildren="false"
                android:clipToOutline="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/listen_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:drawablePadding="10dp"
                    android:gravity="center"
                    android:textAppearance="?attr/textAppearanceHeadlineMedium"
                    android:textColor="?attr/colorOnSurface"
                    app:drawableTint="?attr/colorOnSurface"
                    app:drawableTopCompat="@drawable/ic_capture_wave"
                    tools:text="OFF" />
            </FrameLayout>
        </FrameLayout>


        <!-- Export actions -->
        <LinearLayout
            android:id="@+id/export_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <ImageButton
                android:id="@+id/clear_buffer_button"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_circle_tonal"
                android:contentDescription="@string/clear_buffer"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:scaleType="center"
                android:src="@drawable/ic_delete"
                app:tint="?attr/colorOnSecondaryContainer" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/record_last_max"
                style="@style/Widget.TimeTravel.ExportButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/record_all_memory" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/record_last_custom"
                style="@style/Widget.TimeTravel.ExportButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/custom_time" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/reencode_history_button"
                style="@style/Widget.TimeTravel.ExportButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="2"
                android:text="@string/reencode_history"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>

    <!-- Recording overlay: replaces entire content when actively recording -->
    <FrameLayout
        android:id="@+id/rec_touch_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        tools:visibility="visible"
        android:clipChildren="false"
        android:clipToPadding="false">

        <TextView
            android:id="@+id/rec_button_circle"
            android:layout_width="232dp"
            android:layout_height="232dp"
            android:layout_gravity="center"
            android:clickable="true"
            android:clipToOutline="true"
            android:drawablePadding="12dp"
            android:focusable="true"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceDisplayMedium"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:typeface="monospace"
            app:drawableTint="?attr/colorOnPrimaryContainer"
            app:drawableTopCompat="@drawable/ic_recording"
            tools:text="05:32" />
    </FrameLayout>
</LinearLayout>
