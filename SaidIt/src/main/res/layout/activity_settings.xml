<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent" tools:ignore="Instantiatable">
  <LinearLayout android:id="@+id/settings_layout" android:layout_width="match_parent" android:layout_height="match_parent" android:background="?attr/colorSurface" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="16dp" android:paddingVertical="12dp">
      <ImageButton android:id="@+id/settings_undo_button" android:layout_width="40dp" android:layout_height="40dp" android:alpha="0.38" android:background="@drawable/bg_circle_outlined" android:contentDescription="@string/undo" android:enabled="false" android:minWidth="0dp" android:minHeight="0dp" android:padding="0dp" android:scaleType="center" android:src="@drawable/ic_undo" app:tint="?attr/colorOnSurfaceVariant"/>
      <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
      <ImageButton android:id="@+id/settings_apply_button" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_circle_outlined" android:contentDescription="@string/close" android:minWidth="0dp" android:minHeight="0dp" android:padding="0dp" android:scaleType="center" android:src="@drawable/ic_close" app:tint="?attr/colorOnSurfaceVariant"/>
    </LinearLayout>
    <ScrollView android:id="@+id/settings_scroll" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:clipToPadding="false" android:fillViewport="true">
      <LinearLayout android:id="@+id/settings_content" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingVertical="24dp">
        <com.google.android.material.textfield.TextInputLayout android:id="@+id/theme_layout" style="@style/TimeTravel.TextInputLayout" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/theme_title" app:endIconMode="dropdown_menu" android:layout_marginHorizontal="16dp">
          <com.google.android.material.textfield.MaterialAutoCompleteTextView android:id="@+id/theme_dropdown" style="@style/TimeTravel.DropdownMenu" android:layout_width="match_parent" android:layout_height="wrap_content" android:focusable="false" android:inputType="none"/>
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:layout_marginBottom="24dp" app:dividerColor="?attr/colorOutlineVariant"/>
        <TextView style="?attr/textAppearanceLabelLarge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/retention_mode_title" android:paddingHorizontal="16dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:baselineAligned="false" android:orientation="horizontal" android:paddingHorizontal="16dp">
          <com.google.android.material.textfield.TextInputLayout android:id="@+id/retention_time_layout" style="@style/TimeTravel.TextInputLayout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="@string/retention_time_label">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/retention_time_input" style="@style/TimeTravel.TextInputEditText" android:layout_width="match_parent" android:layout_height="wrap_content" android:digits="0123456789:" android:fontFamily="monospace" android:importantForAutofill="no" android:inputType="textNoSuggestions" android:maxLines="1" android:imeOptions="actionDone" android:selectAllOnFocus="true" tools:text="48:00:00"/>
          </com.google.android.material.textfield.TextInputLayout>
          <com.google.android.material.textfield.TextInputLayout android:id="@+id/retention_size_layout" style="@style/TimeTravel.TextInputLayout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:hint="@string/retention_size_label">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/retention_size_input" style="@style/TimeTravel.TextInputEditText" android:layout_width="match_parent" android:layout_height="wrap_content" android:digits="0123456789.," android:importantForAutofill="no" android:inputType="numberDecimal" android:maxLines="1"/>
          </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:layout_marginBottom="24dp" app:dividerColor="?attr/colorOutlineVariant"/>
        <TextView style="?attr/textAppearanceLabelLarge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/recording_settings_title" android:paddingHorizontal="16dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:baselineAligned="false" android:orientation="horizontal" android:paddingHorizontal="16dp">
          <com.google.android.material.textfield.TextInputLayout android:id="@+id/format_layout" style="@style/TimeTravel.TextInputLayout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="@string/format_label" app:endIconMode="dropdown_menu">
            <com.google.android.material.textfield.MaterialAutoCompleteTextView android:id="@+id/format_dropdown" style="@style/TimeTravel.DropdownMenu" android:layout_width="match_parent" android:layout_height="wrap_content" android:focusable="false" android:inputType="none"/>
          </com.google.android.material.textfield.TextInputLayout>
          <com.google.android.material.textfield.TextInputLayout android:id="@+id/channel_mode_layout" style="@style/TimeTravel.TextInputLayout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:hint="@string/channel_mode_label" app:endIconMode="dropdown_menu">
            <com.google.android.material.textfield.MaterialAutoCompleteTextView android:id="@+id/channel_mode_dropdown" style="@style/TimeTravel.DropdownMenu" android:layout_width="match_parent" android:layout_height="wrap_content" android:focusable="false" android:inputType="none"/>
          </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:baselineAligned="false" android:orientation="horizontal" android:paddingHorizontal="16dp">
          <com.google.android.material.textfield.TextInputLayout android:id="@+id/codec_layout" style="@style/TimeTravel.TextInputLayout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="@string/codec_label" app:endIconMode="dropdown_menu">
            <com.google.android.material.textfield.MaterialAutoCompleteTextView android:id="@+id/codec_dropdown" style="@style/TimeTravel.DropdownMenu" android:layout_width="match_parent" android:layout_height="wrap_content" android:focusable="false" android:inputType="none"/>
          </com.google.android.material.textfield.TextInputLayout>
          <com.google.android.material.textfield.TextInputLayout android:id="@+id/sample_rate_layout" style="@style/TimeTravel.TextInputLayout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:hint="@string/sample_rate_label" app:endIconMode="dropdown_menu">
            <com.google.android.material.textfield.MaterialAutoCompleteTextView android:id="@+id/sample_rate_dropdown" style="@style/TimeTravel.DropdownMenu" android:layout_width="match_parent" android:layout_height="wrap_content" android:focusable="false" android:inputType="none"/>
          </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <LinearLayout android:id="@+id/bitrate_group" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:visibility="gone" android:orientation="vertical" android:paddingHorizontal="16dp">
          <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <TextView style="?attr/textAppearanceLabelLarge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/codec_bitrate_label"/>
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
            <TextView android:id="@+id/bitrate_value" style="?attr/textAppearanceBodyMedium" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/colorOnSurfaceVariant" tools:text="128 kbps"/>
          </LinearLayout>
          <com.google.android.material.slider.Slider android:id="@+id/bitrate_slider" android:layout_width="match_parent" android:layout_height="wrap_content" android:contentDescription="@string/codec_bitrate_label" android:valueFrom="32" android:valueTo="320" android:stepSize="0" android:value="128"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:baselineAligned="false" android:orientation="horizontal" android:paddingHorizontal="16dp">
          <com.google.android.material.textfield.TextInputLayout android:id="@+id/audio_source_layout" style="@style/TimeTravel.TextInputLayout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="@string/audio_source_label" app:endIconMode="dropdown_menu">
            <com.google.android.material.textfield.MaterialAutoCompleteTextView android:id="@+id/audio_source_dropdown" style="@style/TimeTravel.DropdownMenu" android:layout_width="match_parent" android:layout_height="wrap_content" android:focusable="false" android:inputType="none"/>
          </com.google.android.material.textfield.TextInputLayout>
          <com.google.android.material.textfield.TextInputLayout android:id="@+id/input_route_layout" style="@style/TimeTravel.TextInputLayout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:hint="@string/input_route_label" app:endIconMode="dropdown_menu">
            <com.google.android.material.textfield.MaterialAutoCompleteTextView android:id="@+id/input_route_dropdown" style="@style/TimeTravel.DropdownMenu" android:layout_width="match_parent" android:layout_height="wrap_content" android:focusable="false" android:inputType="none"/>
          </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:layout_marginBottom="24dp" app:dividerColor="?attr/colorOutlineVariant"/>
        <TextView style="?attr/textAppearanceLabelLarge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/history_settings_title" android:paddingHorizontal="16dp"/>
        <TextView style="?attr/textAppearanceBodySmall" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/history_chunk_summary" android:textColor="?attr/colorOnSurfaceVariant" android:paddingHorizontal="16dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:baselineAligned="false" android:orientation="horizontal" android:paddingHorizontal="16dp">
          <com.google.android.material.textfield.TextInputLayout android:id="@+id/history_chunk_layout" style="@style/TimeTravel.TextInputLayout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="@string/history_chunk_label">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/history_chunk_input" style="@style/TimeTravel.TextInputEditText" android:layout_width="match_parent" android:layout_height="wrap_content" android:digits="0123456789:" android:fontFamily="monospace" android:importantForAutofill="no" android:imeOptions="actionDone" android:inputType="textNoSuggestions" android:maxLines="1" tools:text="0:10"/>
          </com.google.android.material.textfield.TextInputLayout>
          <com.google.android.material.textfield.TextInputLayout android:id="@+id/auto_merge_layout" style="@style/TimeTravel.TextInputLayout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:hint="@string/auto_merge_label" app:endIconMode="dropdown_menu">
            <com.google.android.material.textfield.MaterialAutoCompleteTextView android:id="@+id/auto_merge_dropdown" style="@style/TimeTravel.DropdownMenu" android:layout_width="match_parent" android:layout_height="wrap_content" android:focusable="false" android:inputType="none"/>
          </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <com.google.android.material.textfield.TextInputLayout android:id="@+id/auto_merge_value_layout" style="@style/TimeTravel.TextInputLayout" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:hint="@string/auto_merge_value_label" android:layout_marginHorizontal="16dp">
          <com.google.android.material.textfield.TextInputEditText android:id="@+id/auto_merge_value_input" style="@style/TimeTravel.TextInputEditText" android:layout_width="match_parent" android:layout_height="wrap_content" android:digits="0123456789:" android:fontFamily="monospace" android:importantForAutofill="no" android:imeOptions="actionDone" android:inputType="textNoSuggestions" android:maxLines="1" tools:text="1:00"/>
        </com.google.android.material.textfield.TextInputLayout>
        <LinearLayout android:id="@+id/auto_merge_eager_row" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="16dp">
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView style="?attr/textAppearanceBodyLarge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_merge_eager_label"/>
            <TextView style="?attr/textAppearanceBodySmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="@string/auto_merge_eager_summary" android:textColor="?attr/colorOnSurfaceVariant"/>
          </LinearLayout>
          <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/auto_merge_eager_switch" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:layout_marginBottom="24dp" app:dividerColor="?attr/colorOutlineVariant"/>
        <TextView style="?attr/textAppearanceLabelLarge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/storage_settings_title" android:paddingHorizontal="16dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="vertical" android:paddingHorizontal="16dp">
          <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <TextView android:id="@+id/export_path_value" style="?attr/textAppearanceBodyLarge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="?attr/colorOnSurfaceVariant" tools:text="App storage/Timetravel"/>
            <ImageButton android:id="@+id/default_folder_button" android:layout_width="44dp" android:layout_height="44dp" android:layout_marginStart="8dp" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/default_folder" android:src="@drawable/ic_reset" android:visibility="gone" app:tint="?attr/colorOnSurfaceVariant"/>
            <ImageButton android:id="@+id/choose_folder_button" android:layout_width="44dp" android:layout_height="44dp" android:layout_marginStart="4dp" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/choose_folder" android:src="@drawable/ic_folder" app:tint="?attr/colorOnSurfaceVariant"/>
          </LinearLayout>
          <com.google.android.material.button.MaterialButton android:id="@+id/move_recordings_button" style="@style/Widget.Material3.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/move_recordings"/>
        </LinearLayout>
        <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:layout_marginBottom="24dp" app:dividerColor="?attr/colorOutlineVariant"/>
        <TextView style="?attr/textAppearanceLabelLarge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/background_persistence_title" android:paddingHorizontal="16dp"/>
        <LinearLayout android:id="@+id/persistent_buffer_row" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="16dp">
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView style="?attr/textAppearanceBodyLarge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/persistent_buffer_cache_label"/>
            <TextView style="?attr/textAppearanceBodySmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="@string/persistent_buffer_cache_summary" android:textColor="?attr/colorOnSurfaceVariant"/>
          </LinearLayout>
          <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/persistent_buffer_switch" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/aggressive_restart_row" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="16dp">
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView style="?attr/textAppearanceBodyLarge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/aggressive_restart_label"/>
            <TextView style="?attr/textAppearanceBodySmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="@string/aggressive_restart_summary" android:textColor="?attr/colorOnSurfaceVariant"/>
          </LinearLayout>
          <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/aggressive_restart_switch" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/wake_lock_row" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="16dp">
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView style="?attr/textAppearanceBodyLarge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/wake_lock_label"/>
            <TextView style="?attr/textAppearanceBodySmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="@string/wake_lock_summary" android:textColor="?attr/colorOnSurfaceVariant"/>
          </LinearLayout>
          <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/wake_lock_switch" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="16dp">
          <TextView android:id="@+id/battery_optimization_status" style="?attr/textAppearanceBodySmall" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="?attr/colorOnSurfaceVariant" tools:text="Battery optimization: restricted"/>
          <com.google.android.material.button.MaterialButton android:id="@+id/battery_optimization_button" style="@style/Widget.Material3.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="@string/battery_optimization_button"/>
        </LinearLayout>
        <com.google.android.material.divider.MaterialDivider android:id="@+id/debug_divider" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:layout_marginBottom="24dp" android:visibility="gone" app:dividerColor="?attr/colorOutlineVariant"/>
        <TextView android:id="@+id/debug_title" style="?attr/textAppearanceLabelLarge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/debug_settings_title" android:paddingHorizontal="16dp" android:visibility="gone"/>
        <LinearLayout android:id="@+id/debug_chunks_row" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="16dp" android:visibility="gone">
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView style="?attr/textAppearanceBodyLarge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/chunks_section_chunks"/>
            <TextView style="?attr/textAppearanceBodySmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="@string/debug_chunks_tab_summary" android:textColor="?attr/colorOnSurfaceVariant"/>
          </LinearLayout>
          <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/debug_chunks_switch" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
      </LinearLayout>
    </ScrollView>
  </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
