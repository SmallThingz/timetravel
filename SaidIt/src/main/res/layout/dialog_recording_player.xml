<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="16dp"
        android:paddingEnd="24dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/player_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="Preparing audio…" />

        <TextView
            android:id="@+id/player_meta_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="AAC-LC • 24 s • 297.5 KB" />

        <SeekBar
            android:id="@+id/player_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:enabled="false"
            android:max="1"
            android:progress="0" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/player_elapsed_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="0:00" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/player_duration_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="0:24" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_seek_back_button"
                style="@style/Widget.TimeTravel.PlayerIconButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:enabled="false"
                android:contentDescription="@string/player_seek_back"
                android:icon="@drawable/ic_seek_back"
                tools:ignore="Instantiatable" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_toggle_button"
                style="@style/Widget.TimeTravel.PlayerIconButton"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="12dp"
                android:enabled="false"
                android:contentDescription="@string/player_play"
                android:icon="@drawable/ic_player_play"
                tools:ignore="Instantiatable" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_seek_forward_button"
                style="@style/Widget.TimeTravel.PlayerIconButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:enabled="false"
                android:contentDescription="@string/player_seek_forward"
                android:icon="@drawable/ic_seek_forward"
                tools:ignore="Instantiatable" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
