<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="8dp"
        android:paddingEnd="24dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/custom_export_scope_group"
                style="@style/Widget.TimeTravel.DialogSegmentGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleSelection="true"
                tools:ignore="Instantiatable">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/custom_export_scope_range_button"
                    style="@style/Widget.TimeTravel.DialogSegmentButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/custom_export_mode_range"
                    tools:ignore="Instantiatable" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/custom_export_scope_past_button"
                    style="@style/Widget.TimeTravel.DialogSegmentButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/custom_export_mode_past"
                    tools:ignore="Instantiatable" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/custom_export_unit_group"
                style="@style/Widget.TimeTravel.DialogSegmentGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                app:selectionRequired="true"
                app:singleSelection="true"
                tools:ignore="Instantiatable">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/custom_export_unit_time_button"
                    style="@style/Widget.TimeTravel.DialogSegmentButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/custom_export_unit_time"
                    tools:ignore="Instantiatable" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/custom_export_unit_size_button"
                    style="@style/Widget.TimeTravel.DialogSegmentButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/custom_export_unit_size"
                    tools:ignore="Instantiatable" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/custom_range_time_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/custom_start_layout"
                    style="@style/TimeTravel.TextInputLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/custom_export_start_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/custom_start_value"
                        style="@style/TimeTravel.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:digits="0123456789:"
                        android:fontFamily="monospace"
                        android:hint="@string/custom_export_duration_hint"
                        android:importantForAutofill="no"
                        android:imeOptions="actionNext"
                        android:inputType="textNoSuggestions"
                        android:maxLines="1"
                        android:selectAllOnFocus="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/custom_end_layout"
                    style="@style/TimeTravel.TextInputLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:hint="@string/custom_export_end_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/custom_end_value"
                        style="@style/TimeTravel.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:digits="0123456789:"
                        android:fontFamily="monospace"
                        android:hint="@string/custom_export_duration_hint"
                        android:importantForAutofill="no"
                        android:imeOptions="actionDone"
                        android:inputType="textNoSuggestions"
                        android:maxLines="1"
                        android:selectAllOnFocus="true" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/custom_range_size_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/custom_start_size_layout"
                    style="@style/TimeTravel.TextInputLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/custom_export_start_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/custom_start_size_value"
                        style="@style/TimeTravel.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:digits="0123456789."
                        android:hint="@string/custom_export_size_hint"
                        android:importantForAutofill="no"
                        android:imeOptions="actionNext"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:selectAllOnFocus="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/custom_end_size_layout"
                    style="@style/TimeTravel.TextInputLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:hint="@string/custom_export_end_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/custom_end_size_value"
                        style="@style/TimeTravel.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:digits="0123456789."
                        android:hint="@string/custom_export_size_hint"
                        android:importantForAutofill="no"
                        android:imeOptions="actionDone"
                        android:inputType="numberDecimal"
                        android:maxLines="1"
                        android:selectAllOnFocus="true" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/custom_past_time_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/custom_past_time_layout"
                style="@style/TimeTravel.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/custom_export_past_label">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/custom_past_time_value"
                    style="@style/TimeTravel.TextInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:digits="0123456789:"
                    android:fontFamily="monospace"
                    android:hint="@string/custom_export_duration_hint"
                    android:importantForAutofill="no"
                    android:imeOptions="actionDone"
                    android:inputType="textNoSuggestions"
                    android:maxLines="1"
                    android:selectAllOnFocus="true" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/custom_past_size_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/custom_past_size_layout"
                style="@style/TimeTravel.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/custom_export_past_label">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/custom_past_size_value"
                    style="@style/TimeTravel.TextInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:digits="0123456789."
                    android:hint="@string/custom_export_size_hint"
                    android:importantForAutofill="no"
                    android:imeOptions="actionDone"
                    android:inputType="numberDecimal"
                    android:maxLines="1"
                    android:selectAllOnFocus="true" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
