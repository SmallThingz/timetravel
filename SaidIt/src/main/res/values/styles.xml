<resources>
    <style name="Theme.TimeTravel" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:textViewStyle">@style/TextView</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.TimeTravel.AlertDialog</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.TimeTravel.AlertDialog</item>
    </style>

    <style name="ThemeOverlay.TimeTravel.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/TimeTravel.ShapeAppearanceOverlay.Dialog</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.TimeTravel.DialogTitle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.TimeTravel.DialogBody</item>
    </style>

    <style name="TimeTravel.ShapeAppearanceOverlay.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="TimeTravel.ShapeAppearanceOverlay.BottomNavIndicator" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">999dp</item>
    </style>

    <style name="Widget.TimeTravel.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">56dp</item>
        <item name="android:height">56dp</item>
        <item name="expandedHeight">56dp</item>
        <item name="marginHorizontal">0dp</item>
        <item name="shapeAppearance">@style/TimeTravel.ShapeAppearanceOverlay.BottomNavIndicator</item>
        <item name="android:color">?attr/colorSecondaryContainer</item>
    </style>

    <style name="TextBase" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="TextView" parent="TextBase" />

    <style name="TextAppearance.TimeTravel.BrandBase" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.045</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">33sp</item>
        <item name="android:lineHeight">33sp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.TimeTravel.BrandAccent" parent="TextAppearance.TimeTravel.BrandBase">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.TimeTravel.DialogTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.TimeTravel.DialogBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>
    <style name="TimeTravel.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">?attr/colorSurfaceContainerHigh</item>
        <item name="boxStrokeColor">?attr/colorOutline</item>
        <item name="boxStrokeErrorColor">?attr/colorError</item>
        <item name="hintTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
        <item name="prefixTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="endIconTint">?attr/colorOnSurfaceVariant</item>
        <item name="errorTextColor">?attr/colorError</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
    </style>

    <style name="TimeTravel.TextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="TimeTravel.DropdownMenu" parent="Widget.Material3.AutoCompleteTextView.OutlinedBox">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="simpleItemSelectedColor">?attr/colorSurfaceVariant</item>
    </style>

    <style name="Widget.TimeTravel.ExportButton" parent="Widget.Material3.Button.TonalButton">
        <item name="shapeAppearanceOverlay">@style/TimeTravel.ShapeAppearanceOverlay.BottomNavIndicator</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="iconPadding">8dp</item>
        <item name="iconTint">?attr/colorOnSecondaryContainer</item>
    </style>

    <style name="Widget.TimeTravel.ExportIconButton" parent="Widget.TimeTravel.ExportButton">
        <item name="android:minWidth">52dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingRight">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="iconPadding">0dp</item>
    </style>

    <style name="Widget.TimeTravel.ClearIconButton" parent="Widget.Material3.Button.IconButton.Filled.Tonal">
        <item name="android:minWidth">52dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearanceOverlay">@style/TimeTravel.ShapeAppearanceOverlay.BottomNavIndicator</item>
        <item name="iconTint">?attr/colorOnSecondaryContainer</item>
    </style>

    <style name="Widget.TimeTravel.DialogSegmentGroup" parent="Widget.Material3.MaterialButtonToggleGroup">
        <item name="android:padding">0dp</item>
    </style>

    <style name="Widget.TimeTravel.DialogSegmentButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">40dp</item>
        <item name="android:minWidth">104dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingLeft">18dp</item>
        <item name="android:paddingRight">18dp</item>
    </style>

    <style name="Widget.TimeTravel.PlayerPrimaryIconButton" parent="Widget.Material3.Button.IconButton.Filled.Tonal">
        <item name="android:minHeight">56dp</item>
        <item name="android:minWidth">56dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearanceOverlay">@style/TimeTravel.ShapeAppearanceOverlay.BottomNavIndicator</item>
        <item name="iconPadding">0dp</item>
        <item name="iconTint">?attr/colorOnSecondaryContainer</item>
    </style>

    <style name="Widget.TimeTravel.PlayerSideIconButton" parent="Widget.Material3.Button.IconButton.Outlined">
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearanceOverlay">@style/TimeTravel.ShapeAppearanceOverlay.BottomNavIndicator</item>
        <item name="iconPadding">0dp</item>
        <item name="iconTint">?attr/colorOnSurface</item>
    </style>

    <style name="Widget.TimeTravel.DialogCloseButton" parent="Widget.Material3.Button.IconButton">
        <item name="android:minHeight">40dp</item>
        <item name="android:minWidth">40dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearanceOverlay">@style/TimeTravel.ShapeAppearanceOverlay.BottomNavIndicator</item>
        <item name="iconPadding">0dp</item>
        <item name="iconTint">?attr/colorOnSurfaceVariant</item>
    </style>
</resources>
