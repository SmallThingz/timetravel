<resources>
    <style name="Theme.TimeTravel" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:textViewStyle">@style/TextView</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.TimeTravel.AlertDialog</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.TimeTravel.AlertDialog</item>
    </style>

    <style name="ThemeOverlay.TimeTravel.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog" />

    <style name="TextBase" parent="android:Widget.TextView">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">@dimen/info_text_size</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="TextView" parent="TextBase" />

    <style name="EmphasizedText" parent="TextView">
        <item name="android:textSize">@dimen/emph_text_size</item>
        <item name="android:typeface">monospace</item>
    </style>

    <style name="HeadlineText" parent="TextView">
        <item name="android:textSize">30sp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="SectionTitle" parent="TextView">
        <item name="android:textSize">24sp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="SectionTitleSmall" parent="TextView">
        <item name="android:textSize">18sp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="BodyText" parent="TextView">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">15sp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="LabelText" parent="TextView">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">12sp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="MetricText" parent="EmphasizedText">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">28sp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="DialogPanel">
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="TimeTravel.MaterialButton.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">56dp</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_margin">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="cornerRadius">20dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="TimeTravel.MaterialButton.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">52dp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_margin">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">20dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="TimeTravel.MaterialButton.Secondary.Small" parent="TimeTravel.MaterialButton.Secondary">
        <item name="android:minHeight">44dp</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TimeTravel.MaterialButton.Danger" parent="Widget.Material3.Button">
        <item name="android:minHeight">56dp</item>
        <item name="android:textColor">?attr/colorOnErrorContainer</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_margin">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">?attr/colorErrorContainer</item>
        <item name="cornerRadius">20dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="TimeTravel.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">?attr/colorOutline</item>
        <item name="hintTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
    </style>

    <style name="TimeTravel.TextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
    </style>
</resources>
