<resources>
    <style name="Theme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:textViewStyle">@style/TextView</item>
        <item name="android:windowBackground">@color/background_canvas</item>
        <item name="android:statusBarColor">@color/background_canvas</item>
        <item name="android:navigationBarColor">@color/background_canvas</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/text_inverse</item>
        <item name="colorSurface">@color/background_panel</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOutline">@color/border_subtle</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.Echo.AlertDialog</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Echo.AlertDialog</item>
    </style>

    <style name="ThemeOverlay.Echo.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/background_panel</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="ButtonBase" parent="Widget.AppCompat.Button">
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/button_text_size</item>
        <item name="android:background">@drawable/gray_button</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:paddingTop">@dimen/button_padding</item>
        <item name="android:paddingBottom">@dimen/button_padding</item>
        <item name="android:paddingLeft">@dimen/small_round</item>
        <item name="android:paddingRight">@dimen/small_round</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="Button" parent="ButtonBase">
        <item name="android:shadowRadius">0.01</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">2</item>
        <item name="android:shadowColor">@color/shadow_base</item>
    </style>

    <style name="Ticket">
        <item name="android:background">@drawable/ticket</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/ticket_text_size</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:shadowRadius">0</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowColor">@color/transparent</item>
    </style>

    <style name="CircleButton" parent="ButtonBase">
        <item name="android:background">@drawable/circle_button</item>
        <item name="android:layout_margin">12dp</item>
    </style>

    <style name="GreenButton" parent="ButtonBase">
        <item name="android:background">@drawable/green_button</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="android:shadowRadius">0.01</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">4</item>
        <item name="android:shadowColor">@color/accent_deep</item>
    </style>

    <style name="HeroButton" parent="GreenButton">
        <item name="android:background">@drawable/top_green_button</item>
        <item name="android:textSize">20sp</item>
        <item name="android:minHeight">68dp</item>
        <item name="android:layout_margin">0dp</item>
    </style>

    <style name="TextBase" parent="android:Widget.TextView">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/info_text_size</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="TextView" parent="TextBase" />

    <style name="EmphasizedText" parent="TextView">
        <item name="android:textSize">@dimen/emph_text_size</item>
        <item name="android:typeface">monospace</item>
    </style>

    <style name="SmallText">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/small_text_size</item>
    </style>

    <style name="HeroCard">
        <item name="android:background">@drawable/panel_surface_emphasis</item>
        <item name="android:padding">@dimen/hero_padding</item>
    </style>

    <style name="SectionCard">
        <item name="android:background">@drawable/panel_surface</item>
        <item name="android:padding">@dimen/card_padding</item>
    </style>

    <style name="SectionCardRecording">
        <item name="android:background">@drawable/panel_surface_recording</item>
        <item name="android:padding">@dimen/card_padding</item>
    </style>

    <style name="HeroEyebrow" parent="TextView">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.18</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="HeadlineText" parent="TextView">
        <item name="android:textSize">34sp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="SectionTitle" parent="TextView">
        <item name="android:textSize">24sp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="SectionTitleSmall" parent="TextView">
        <item name="android:textSize">20sp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="BodyText" parent="TextView">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="LabelText" parent="TextView">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="MetricText" parent="EmphasizedText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">30sp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="MetricTextCenter" parent="MetricText">
        <item name="android:gravity">center</item>
    </style>

    <style name="InputField" parent="android:Widget.EditText">
        <item name="android:background">@drawable/bg_et</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:padding">@dimen/input_padding</item>
        <item name="android:gravity">center_vertical</item>
    </style>
</resources>
